generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum UserRole {
  STUDENT
  PROFESSIONAL
  ADMIN
}

enum SessionStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum SpecializationType {
  PERSONAL_TRAINING
  YOGA
  PILATES
  MARTIAL_ARTS
  CROSSFIT
  SWIMMING
  NUTRITION_COACHING
  DANCE
  CYCLING
  REHABILITATION
  MEDITATION
  FUNCTIONAL_TRAINING
}

enum SessionModality {
  IN_PERSON
  ONLINE
  HYBRID
}

enum AvailabilityRecurrence {
  ONCE
  WEEKLY
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String?
  phone         String?
  avatarUrl     String?
  image         String?
  emailVerified DateTime? @map("email_verified")
  role          UserRole  @default(STUDENT)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student      Student?
  professional Professional?
  accounts     Account[]
  authSessions Session[]     @relation("AuthSessions")
  sentMessages Message[]     @relation("MessageSender")

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation("AuthSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Student {
  id                       String               @id @default(cuid())
  userId                   String               @unique
  user                     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  fitnessGoals             String[]
  experienceLevel          ExperienceLevel
  preferredModality        SessionModality
  preferredSpecializations SpecializationType[]
  bio                      String?
  locationStreet           String?
  locationCity             String?
  locationState            String?
  locationCountry          String?
  locationPostal           String?
  locationLat              Float?
  locationLng              Float?
  budgetMin                Int?
  budgetMax                Int?
  budgetCurrency           String?              @default("BRL")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions TrainingSession[]
  reviews  Review[]
  matches  Match[]
  favoriteProfessionals StudentFavorite[]
  conversations Conversation[]

  @@map("students")
}

model AreaAtuacao {
  id     String @id @default(cuid())
  nome   String @unique
  slug   String @unique
  ativo  Boolean @default(true)
  ordem  Int     @default(0)

  profissionais ProfessionalArea[]

  @@map("areas_atuacao")
}

model ProfessionalArea {
  professionalId String
  areaId         String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  area           AreaAtuacao  @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([professionalId, areaId])
  @@map("professional_areas")
}

model Professional {
  id                 String               @id @default(cuid())
  userId             String               @unique
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                String
  modalities         SessionModality[]
  yearsExperience    Int
  isVerified         Boolean              @default(false)
  isAcceptingClients Boolean              @default(true)
  averageRating      Float?
  totalReviews       Int                  @default(0)
  priceMin           Int
  priceMax           Int
  priceCurrency      String               @default("BRL")
  locationStreet     String
  locationCity       String
  locationState      String
  locationCountry    String
  locationPostal     String
  locationLat        Float?
  locationLng        Float?
  crefNumber             String?
  classDynamics          String?
  sessionDurationMinutes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  areas                 ProfessionalArea[]
  specializationRecords Specialization[]
  certifications        Certification[]
  availabilities        Availability[]
  sessions              TrainingSession[]
  reviews               Review[]
  matches               Match[]
  favoritedByStudents   StudentFavorite[]
  conversations         Conversation[]

  @@index([locationCity, locationState])
  @@index([isAcceptingClients, averageRating])
  @@map("professionals")
}

model Specialization {
  id                 String             @id @default(cuid())
  professionalId     String
  professional       Professional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  type               SpecializationType
  yearsExperience    Int
  description        String?
  subSpecializations String[]
  createdAt          DateTime           @default(now())

  @@unique([professionalId, type])
  @@map("specializations")
}

model Certification {
  id             String       @id @default(cuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  name           String
  issuingBody    String
  issueDate      DateTime
  expiryDate     DateTime?
  documentUrl    String?
  isVerified     Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@map("certifications")
}

model Availability {
  id             String                 @id @default(cuid())
  professionalId String
  professional   Professional           @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  dayOfWeek      Int?
  startTime      DateTime
  endTime        DateTime
  recurrence     AvailabilityRecurrence
  isBooked       Boolean                @default(false)
  validFrom      DateTime
  validUntil     DateTime?

  sessions TrainingSession[]

  @@index([professionalId, isBooked])
  @@index([professionalId, startTime, endTime])
  @@map("availabilities")
}

model StudentFavorite {
  id               String       @id @default(cuid())
  studentId        String
  student          Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  professionalId   String
  professional     Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())

  @@unique([studentId, professionalId])
  @@index([studentId])
  @@map("student_favorites")
}

model Match {
  id             String       @id @default(cuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])
  score          Float
  reasoning      String       @db.Text
  aiModelVersion String
  status         MatchStatus  @default(PENDING)
  requestedAt    DateTime     @default(now())
  respondedAt    DateTime?
  expiresAt      DateTime

  sessions TrainingSession[]
  conversations Conversation[]

  @@index([studentId, status])
  @@index([expiresAt])
  @@map("matches")
}

model TrainingSession {
  id                 String          @id @default(cuid())
  studentId          String
  student            Student         @relation(fields: [studentId], references: [id])
  professionalId     String
  professional       Professional    @relation(fields: [professionalId], references: [id])
  matchId            String?
  match              Match?          @relation(fields: [matchId], references: [id])
  availabilityId     String
  availability       Availability    @relation(fields: [availabilityId], references: [id])
  startTime          DateTime
  endTime            DateTime
  modality           SessionModality
  priceInCents       Int
  currency           String          @default("BRL")
  status             SessionStatus   @default(PENDING)
  cancellationReason String?
  cancelledBy        String?
  completedAt        DateTime?
  locationStreet     String?
  locationCity       String?
  locationState      String?
  locationCountry    String?
  locationPostal     String?

  onlineMeetingUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review?

  @@index([studentId, status])
  @@index([professionalId, status])
  @@index([startTime])
  @@map("sessions")
}

model Review {
  id             String          @id @default(cuid())
  sessionId      String          @unique
  session        TrainingSession @relation(fields: [sessionId], references: [id])
  studentId      String
  student        Student         @relation(fields: [studentId], references: [id])
  professionalId String
  professional   Professional    @relation(fields: [professionalId], references: [id])
  rating         Int
  comment        String?         @db.Text
  isPublic       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([professionalId, isPublic])
  @@map("reviews")
}

model Conversation {
  id                 String             @id @default(cuid())
  studentId          String
  student            Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  professionalId     String
  professional       Professional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  fromMatchId        String?
  fromMatch          Match?             @relation(fields: [fromMatchId], references: [id])
  status             ConversationStatus @default(ACTIVE)
  lastMessageAt      DateTime?
  lastMessagePreview String?            @db.VarChar(160)
  studentUnread      Int                @default(0)
  professionalUnread Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  messages Message[]

  @@unique([studentId, professionalId])
  @@index([studentId, lastMessageAt])
  @@index([professionalId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId   String
  sender         User         @relation("MessageSender", fields: [senderUserId], references: [id])
  body           String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}
